# Option A: official OpenAI
OPENAI_API_KEY=sk-your-key-here
# Optional: choose a specific OpenAI model instead of the SDK default.
# OPENAI_MODEL=gpt-your-model-name

# Option B: local Ollama, used automatically when OPENAI_API_KEY is empty and Ollama is running.
# LOCAL_BASE_URL=http://localhost:11434/v1
# LOCAL_MODEL=qwen2.5:7b

# Option C: another OpenAI-compatible provider.
# OPENAI_BASE_URL=https://your-provider.example/v1
# OPENAI_API_KEY=your-provider-key
# OPENAI_MODEL=your-model-name
# OPENAI_API_MODE=chat_completions

# Optional: Lesson 05 Apify LinkedIn Jobs MCP demo.
# APIFY_API_TOKEN=apify_api_your-token-here
